; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="restock"
run/main_scene="uid://cfecg4ehkgkbl"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

LocalizationService="*uid://b6npd7cd5hqrq"
Const="*uid://dxvugxni0x6mo"

[display]

window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://assets/localization/game.de.translation", "res://assets/localization/game.en.translation")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

